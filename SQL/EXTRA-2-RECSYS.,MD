## 10. Category Affinity Recommendations

**"User 101 buys 60% Electronics → show them top Electronics they haven't seen."**

```sql
-- Step 1: Compute what fraction of each user's purchases are in each category
WITH user_category_affinity AS (
  SELECT
    o.user_id,
    p.category,
    COUNT(*)     AS purchases_in_category,
    SUM(o.amount) AS spend_in_category,
    -- Window function: what % of this user's total purchases is this category?
    ROUND(COUNT(*) * 1.0 /
      SUM(COUNT(*)) OVER (PARTITION BY o.user_id), 4) AS category_affinity
  FROM orders o
  JOIN products p ON o.product_id = p.product_id
  GROUP BY o.user_id, p.category
),
-- Step 2: Top products per category by popularity
top_products_per_category AS (
  SELECT
    p.category,
    o.product_id,
    COUNT(DISTINCT o.user_id)  AS buyers,
    RANK() OVER (
      PARTITION BY p.category
      ORDER BY COUNT(DISTINCT o.user_id) DESC
    ) AS category_rank
  FROM orders o
  JOIN products p ON o.product_id = p.product_id
  GROUP BY p.category, o.product_id
)
-- Step 3: Cross user's top categories with top products in those categories
SELECT
  uca.user_id,
  uca.category,
  uca.category_affinity,
  tp.product_id,
  tp.category_rank,
  tp.buyers
FROM user_category_affinity uca
JOIN top_products_per_category tp
  ON  tp.category      = uca.category
  AND tp.category_rank <= 5          -- top 5 products per category
WHERE uca.category_affinity >= 0.20  -- only categories with ≥20% of purchases
  AND tp.product_id NOT IN (
    SELECT product_id FROM orders WHERE user_id = uca.user_id
  )
ORDER BY uca.user_id, uca.category_affinity DESC, tp.category_rank;
```

